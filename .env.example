# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=collnotes

# Backend database connection (must match postgres credentials above)
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/collnotes

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# App
NODE_ENV=production
PORT=3001
WS_PORT=3002
FRONTEND_URL=https://your-domain.com
